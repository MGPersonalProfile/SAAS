# Supabase
# Obtén estos valores desde: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Solo para scripts del servidor (seeds, migraciones, tareas admin).
# NUNCA exponer al cliente. NUNCA commitear.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# URL pública del sitio (para emails de Supabase, OAuth callbacks, etc.)
# En desarrollo: http://localhost:3000
# En producción: https://chfm.tu-dominio.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
